
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  type      UserType
  lojaId         String?
  loja           Loja?      @relation(fields: [lojaId], references: [id])
  lojasRegionais UserLoja[]
  regiaoId       String?
  regiao         Regiao?    @relation(fields: [regiaoId], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

enum UserType {
  LOJA          // visualiza somente a loja vinculada
  GERENTE       // visualiza somente as lojas da sua região (só leitura)
  DIRECAO       // visualiza todas as lojas + comparativo de regiões (só leitura)
  ADMINISTRATIVO // DIRECAO + gerencia metas
  TI            // acesso total: metas, lojas, usuários e regiões
}

model Loja {
  id                      String                    @id @default(uuid())
  name                    String
  sigla                   String?                   @unique
  cnpj                    String                    @unique
  codigoLicenca           String?
  cidade                  String?
  endereco                String?
  usuarios                User[]
  regionais               UserLoja[]
  regioes                 RegiaoLoja[]
  metasFinanceiras        MetaFinanceira[]
  metasOperacionais       MetaOperacional[]
  historicoFinanceiro     HistoricoMetaFinanceira[]
  historicoOperacional    HistoricoMetaOperacional[]
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
}

// Tabela de junção: gerente regional ↔ lojas atribuídas
model UserLoja {
  userId  String
  lojaId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  loja    Loja   @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@id([userId, lojaId])
}

// Grupos de lojas (regiões) para gerentes regionais
model Regiao {
  id        String      @id @default(uuid())
  nome      String      @unique
  lojas     RegiaoLoja[]
  users     User[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model RegiaoLoja {
  regiaoId String
  lojaId   String
  regiao   Regiao @relation(fields: [regiaoId], references: [id], onDelete: Cascade)
  loja     Loja   @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  @@id([regiaoId, lojaId])
}

// Recurso 1.3: KRs Financeiros (Prosperidade com Segurança)
model MetaFinanceira {
  id                 String   @id @default(uuid())
  trimestre          String   @db.VarChar(10)

  // KR 1: Cartão (%)
  cartaoAtual        Float?
  cartaoMeta         Float

  // KR 2: À Vista (%)
  avistaAtual        Float?
  avistaMeta         Float

  // KR 2b: Crediário (%) — armazenado, não exibido no dashboard
  crediarioMeta      Float?

  // KR 3: Ticket Médio (R$)
  ticketAtual        Decimal? @db.Decimal(10, 2)
  ticketMeta         Decimal  @db.Decimal(10, 2)

  // KR 4: Inadimplência (%) - defasagem 3 meses
  inadimplenciaAtual Float?
  inadimplenciaMeta  Float

  // Totalizadores do KPI strip
  totalVendas        Int?
  valorTotal         Decimal? @db.Decimal(14, 2)

  // Rastreamento do cálculo
  lastCalculatedAt   DateTime?
  calculationStatus  String    @default("pending")
  errorMessage       String?   @db.Text

  lojaId             String
  loja               Loja      @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([lojaId, trimestre])
  @@index([lojaId, trimestre])
}

// Recurso 1.4: KRs Operacionais (Operar com Excelência)
model MetaOperacional {
  id                 String   @id @default(uuid())
  trimestre          String   @db.VarChar(10)

  // KR 1: Garantias e Cancelamentos (%)
  garantiasAtual     Float?
  garantiasMeta      Float    @default(5)
  garantiasQtd       Int?
  garantiasTotal     Int?

  // KR 2: Vendas Luzter (% do faturamento de lentes)
  luzterAtual        Float?
  luzterMeta         Float    @default(85)
  valorLuzter        Float?
  valorTotalLentes   Float?
  detalhesLuzter     Json?
  luzterOutrasPct    Float?
  luzterOutrasValor  Float?

  // KR 3: Vendas Binni/Volt (% do faturamento de armações)
  binniAtual         Float?
  binniMeta          Float    @default(35)
  valorBinni         Float?
  valorTotalArmacoes Float?
  detalhesBinni      Json?
  binniOutrasPct     Float?
  binniOutrasValor   Float?

  // Rastreamento do cálculo
  lastCalculatedAt   DateTime?
  calculationStatus  String    @default("pending")
  errorMessage       String?   @db.Text

  lojaId             String
  loja               Loja      @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([lojaId, trimestre])
  @@index([lojaId, trimestre])
}

// Histórico de snapshots: Financeiro
model HistoricoMetaFinanceira {
  id                 String   @id @default(uuid())
  trimestre          String   @db.VarChar(10)

  cartaoAtual        Float?
  cartaoMeta         Float
  avistaAtual        Float?
  avistaMeta         Float
  crediarioMeta      Float?
  ticketAtual        Decimal? @db.Decimal(10, 2)
  ticketMeta         Decimal  @db.Decimal(10, 2)
  inadimplenciaAtual Float?
  inadimplenciaMeta  Float
  totalVendas        Int?
  valorTotal         Decimal? @db.Decimal(14, 2)

  calculationStatus  String
  errorMessage       String?  @db.Text

  lojaId             String
  loja               Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  snapshotEm         DateTime @default(now())

  @@index([lojaId, trimestre])
  @@index([snapshotEm])
}

// Histórico de snapshots: Operacional
model HistoricoMetaOperacional {
  id                 String   @id @default(uuid())
  trimestre          String   @db.VarChar(10)

  garantiasAtual     Float?
  garantiasMeta      Float
  garantiasQtd       Int?
  garantiasTotal     Int?

  luzterAtual        Float?
  luzterMeta         Float
  valorLuzter        Float?
  valorTotalLentes   Float?
  detalhesLuzter     Json?
  luzterOutrasPct    Float?
  luzterOutrasValor  Float?

  binniAtual         Float?
  binniMeta          Float
  valorBinni         Float?
  valorTotalArmacoes Float?
  detalhesBinni      Json?
  binniOutrasPct     Float?
  binniOutrasValor   Float?

  calculationStatus  String
  errorMessage       String?  @db.Text

  lojaId             String
  loja               Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  snapshotEm         DateTime @default(now())

  @@index([lojaId, trimestre])
  @@index([snapshotEm])
}
